{
  "name": "@clinicos/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate --schema=../prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:seed": "node dist/seed.js",
    "prisma:seed": "node dist/seed.js",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=../prisma/schema.prisma",
    "test": "node ../scripts/run-node-tests.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ajv": "^8.20.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "jose": "^6.2.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0"
  }
}
