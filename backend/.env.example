DATABASE_URL="postgresql://user:password@host:5432/clinicos?schema=public"
PORT=3001
NODE_ENV=production

# URL principale del frontend Vercel (production)
FRONTEND_URL=https://clinicos-eosin.vercel.app

# Lista separata da virgole: production + tutte le preview URL Vercel
FRONTEND_URLS=https://clinicos-eosin.vercel.app,https://clinicos-el91lyszt-lucalavia-2482s-projects.vercel.app

# Nota: in Railway impostare queste variabili nel pannello Variables del servizio backend.
# Le URL *.vercel.app che contengono 'clinicos' vengono accettate automaticamente
# anche senza configurazione esplicita (supporto preview branch).

# ── AI / Importa lettera di dimissioni (REQ-013) ────────────────────────────
# Tutte server-side. NESSUNA di queste va nel frontend o in variabili VITE_*.
AI_PROVIDER=google
AI_MODEL=gemma-4-31b-it
# Modello separato per output strutturato, se il modello principale non supporta schema (opzionale).
# AI_STRUCTURED_MODEL=gemini-2.0-flash
# SEGRETO: impostare SOLO nel secret manager Railway, mai nel repository.
GEMINI_API_KEY=
# Path agli asset versionati (default: backend/ai-assets/*). Override solo se necessario.
# AI_EXTRACTION_SCHEMA_PATH=
# AI_EXTRACTION_PROMPT_PATH=
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
AI_MAX_FILES=10
AI_MAX_TOTAL_MB=25
