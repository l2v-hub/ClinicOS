generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OPERATOR
  MANAGER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  passwordHash        String
  fullName            String
  role                Role          @default(OPERATOR)
  isActive            Boolean       @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  operator            Operator?
  appointmentsCreated Appointment[] @relation("AppointmentCreatedBy")
}

model Operator {
  id                 String           @id @default(cuid())
  userId             String           @unique
  licenseNumber      String?          @unique
  department         String?
  phone              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredPatients Patient[]        @relation("PatientRegisteredBy")
  appointments       Appointment[]    @relation("AppointmentOperator")
  clinicalRecords    ClinicalRecord[] @relation("ClinicalRecordAuthor")
  clinicalNotes      ClinicalNote[]   @relation("ClinicalNoteAuthor")
}

model Patient {
  id                    String           @id @default(cuid())
  medicalRecordNumber   String           @unique
  firstName             String
  lastName              String
  dateOfBirth           DateTime
  sex                   String?
  email                 String?
  phone                 String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  registeredById        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  registeredBy          Operator?        @relation("PatientRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  clinicalRecords       ClinicalRecord[]
  appointments          Appointment[]
  cartella              Cartella?
  medicationAdministrations MedicationAdministration[]
  intakeDocuments           PatientIntakeDocument[]
  therapies                 PatientTherapy[]
  roomAssignments           PatientRoomAssignment[]
  diaryEntries              PatientDiaryEntry[]
  narrativeSections         PatientNarrativeSection[]
  documents                 PatientDocument[]

  @@index([lastName, firstName])
  @@index([registeredById])
}

// ── Patient narrative clinical sections (REQ-029) ─────────────────────────────
// Faithful narrative text per canonical clinical section (imported from a discharge
// letter OR filled manually). originalText is immutable; operator edits go to
// reviewedText. NOT a replacement for legacy structured data — coexists with it.
model PatientNarrativeSection {
  id               String   @id @default(cuid())
  patientId        String
  // ALLERGIES|DIAGNOSIS|ANAMNESIS|HOSPITAL_COURSE|CONSULTATIONS|IMAGING_DIAGNOSTICS|
  // PROCEDURES_AND_INTERVENTIONS|THERAPY|ADVICE_AND_FOLLOW_UP|UNMAPPED_CONTENT
  sectionKey       String
  detectedHeading  String?
  originalText     String   @default("")   // TEXT, immutable (as imported)
  reviewedText     String?                 // TEXT, operator correction (display wins over original)
  annotations      Json?                   // JSONB — semantic bold tags (offsets)
  sourceReferences Json?                   // JSONB — file/page provenance
  importJobId      String?
  reviewStatus     String   @default("pending") // pending|reviewed|modified|absent|conflict
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, sectionKey])
  @@index([patientId])
}

// ── Imported documents permanently linked to the patient (REQ-035 v2) ─────────
// File bytes are kept IN Postgres (base64) like PatientIntakeDocument, so they survive
// Railway redeploy/restart with no external object storage. onDelete: Cascade means deleting
// the patient removes the documents (and their bytes) — no orphan storage to clean up.
model PatientDocument {
  id           String   @id @default(cuid())
  patientId    String
  importJobId  String?
  originalName String
  mimeType     String
  sizeBytes    Int
  sha256       String
  dataBase64   String   // base64 file content (persistent, in-DB)
  documentType String   @default("discharge_import")
  sortOrder    Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Cartella {
  id        String   @id @default(cuid())
  patientId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ClinicalRecord {
  id               String         @id @default(cuid())
  patientId        String
  authorOperatorId String
  appointmentId    String?        @unique
  chiefComplaint   String?
  diagnosis        String?
  treatmentPlan    String?
  recordedAt       DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  patient          Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorOperator   Operator       @relation("ClinicalRecordAuthor", fields: [authorOperatorId], references: [id], onDelete: Restrict)
  appointment      Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  notes            ClinicalNote[]

  @@index([patientId])
  @@index([authorOperatorId])
}

model ClinicalNote {
  id               String         @id @default(cuid())
  clinicalRecordId String
  authorOperatorId String
  note             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  authorOperator   Operator       @relation("ClinicalNoteAuthor", fields: [authorOperatorId], references: [id], onDelete: Restrict)

  @@index([clinicalRecordId])
  @@index([authorOperatorId])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  operatorId      String
  createdByUserId String
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  reason          String?
  notes           String?
  status          AppointmentStatus @default(SCHEDULED)
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  operator        Operator          @relation("AppointmentOperator", fields: [operatorId], references: [id], onDelete: Restrict)
  createdBy       User              @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  clinicalRecord  ClinicalRecord?

  @@index([patientId, scheduledAt])
  @@index([operatorId, scheduledAt])
  @@index([createdByUserId])
  @@index([status, scheduledAt])
}

model MedicationAdministration {
  id            String    @id @default(cuid())
  patientId     String
  farmacoNome   String
  farmacoDose   String
  farmacoVia    String    @default("orale")
  date          String    // YYYY-MM-DD
  fascia        String    // mattina, pranzo, pomeriggio, sera, notte
  ora           String    // 08:00, 12:00, 16:00, 20:00, 22:00
  stato         String    @default("da_erogare") // da_erogare, erogata, non_erogata
  operatoreId   String?
  operatoreNome String?
  confirmedAt   DateTime?
  motivo        String?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, farmacoNome, date, fascia])
  @@index([date, fascia])
  @@index([patientId])
}

model PatientIntakeDocument {
  id            String   @id @default(cuid())
  fileName      String
  fileType      String
  fileData      String   // base64 encoded file content
  ocrText       String?  // extracted OCR text
  extractedData Json?    // structured extracted data
  status        String   @default("uploaded") // uploaded, ocr_complete, extracted, applied
  patientId     String?
  operatoreNome String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  patient       Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([status])
}

model PatientTherapy {
  id                   String   @id @default(cuid())
  patientId            String
  farmacoNome          String
  dosaggio             String
  viaSomministrazione  String   @default("orale")
  tipo                 String   @default("periodica") // periodica | una_tantum
  stato                String   @default("attiva")    // attiva | sospesa | conclusa
  dataInizio           String   // YYYY-MM-DD
  dataFine             String?  // YYYY-MM-DD optional
  fasceMattina         Boolean  @default(false)
  fascePranzo          Boolean  @default(false)
  fascePomeriggio      Boolean  @default(false)
  fasceSera            Boolean  @default(false)
  fasceNotte           Boolean  @default(false)
  orarioSpecifico      String?  // comma-separated specific times e.g. "08:00,12:00,16:00"
  prescrittore         String?
  operatoreInseritore  String?
  note                 String?
  // Una tantum specific
  dataSomministrazione String?  // YYYY-MM-DD for una tantum
  orarioSomministrazione String? // HH:MM for una tantum
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([tipo, stato])
}

// ── Rooms & Beds ───────────────────────────────────────────────────────────

enum RoomType {
  singola
  doppia
  altra
}

enum RoomStatus {
  attiva
  inattiva
  manutenzione
}

model Room {
  id        String     @id @default(cuid())
  numero    String     @unique
  tipo      RoomType   @default(singola)
  piano     String     @default("")
  reparto   String     @default("")
  stato     RoomStatus @default(attiva)
  note      String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  beds      Bed[]
}

model Bed {
  id          String                @id @default(cuid())
  roomId      String
  label       String                // "A", "B", "C"
  stato       String                @default("libero") // libero, manutenzione (occupato is calculated)
  note        String                @default("")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  room        Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments PatientRoomAssignment[]

  @@unique([roomId, label])
  @@index([roomId])
}

model PatientRoomAssignment {
  id          String    @id @default(cuid())
  patientId   String
  roomId      String
  bedId       String
  startDate   String    // YYYY-MM-DD
  endDate     String?   // YYYY-MM-DD, null = still assigned
  note        String    @default("")
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  bed         Bed       @relation(fields: [bedId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([bedId])
  @@index([startDate, endDate])
}

model Consegna {
  id                 String   @id @default(cuid())
  pazienteId         String   @default("")
  pazienteNome       String
  priorita           String   @default("normale") // normale | alta | urgente
  stato              String   @default("aperta")   // aperta | in_corso | completata
  tipo               String   @default("Monitoraggio")
  note               String
  scadenza           String   // YYYY-MM-DD
  oraScadenza        String?
  operatoreAssegnato String
  creatoDA           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([stato])
  @@index([priorita])
}

model Nota {
  id               String   @id @default(cuid())
  autoreId         String
  autoreNome       String
  destinatarioId   String   // operatoreId | 'admin' | 'tutti'
  destinatarioNome String
  pazienteId       String?
  pazienteNome     String?
  priorita         String   @default("normale") // normale | alta | urgente
  messaggio        String
  stato            String   @default("non_letta") // non_letta | letta | risolta
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stato])
  @@index([destinatarioId])
}

model PatientDiaryEntry {
  id            String   @id @default(cuid())
  patientId     String
  authorType    String   // medico | infermiere | oss | fisioterapista | operatore | altro
  authorName    String
  title         String?
  content       String
  priority      String   @default("normale")  // normale | importante | urgente
  status        String   @default("aperta")   // aperta | completata | da_rivedere
  entryDateTime String   // ISO datetime string YYYY-MM-DDTHH:mm
  category      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([authorType])
  @@index([entryDateTime])
}

// ── AI discharge-letter import (REQ-014) ──────────────────────────────────────
// Temporary, pre-patient document import. No Patient data is written here:
// confirmation/persistence is REQ-018. File bytes live on disk (storagePath),
// only metadata + hash are stored in the DB.
model ImportJob {
  id             String           @id @default(cuid())
  // created|uploaded|queued|uploading_to_google|waiting_for_model|validating_response|
  // repairing_response|review_ready|retryable_error|failed|cancelled|confirmed (REQ-022)
  status         String           @default("uploaded")
  // Coarse stage for the UI (uploading_files | model_processing | completed | error).
  stage          String?
  currentFileName String?
  errorCode      String?
  attempts       Int              @default(0)
  // When the worker started processing (for elapsedSeconds).
  startedAt      DateTime?
  idempotencyKey String?          @unique
  maxFiles       Int
  maxTotalBytes  Int
  totalBytes     Int              @default(0)
  error          String?
  resultData     Json?            // populated by extraction (REQ-015)
  model          String?
  schemaVersion  String?
  promptVersion  String?
  createdById    String?
  // REQ-018: set only after the reviewed patient is committed (audit linkage).
  createdPatientId String?
  confirmedAt    DateTime?
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  documents      ImportDocument[]
  auditEvents    ImportAudit[]

  @@index([status])
  @@index([expiresAt])
  @@index([createdPatientId])
}

// REQ-018: audit trail linking job ↔ patient ↔ documents. No clinical content.
model ImportAudit {
  id          String    @id @default(cuid())
  jobId       String
  patientId   String?
  action      String    // confirm_started | patient_created | confirm_committed | duplicate_flagged | confirm_failed
  detail      String?   // short, content-free note
  createdAt   DateTime  @default(now())
  job         ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([patientId])
}

model ImportDocument {
  id           String    @id @default(cuid())
  jobId        String
  filename     String
  mimeType     String
  sizeBytes    Int
  sha256       String
  storagePath  String
  // BUG-049: durable copy of the bytes in the DB so the import file survives Railway's ephemeral
  // filesystem (container restart / sweep) and can still be persisted as a PatientDocument at confirm.
  dataBase64   String?
  sortOrder    Int       @default(0)
  logicalDoc   String?   // group multiple photos into one logical document
  // pending|uploading|uploaded|processing|completed|retryable_error|failed|duplicate|rejected
  status       String    @default("uploaded")
  rejectReason String?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  job          ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sha256])
  @@index([jobId])
}
