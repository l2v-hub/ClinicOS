# ClinicOS AI Runtime (REQ-023/024) — server-side only. Set in the Railway service
# `clinicos-ai-runtime`. Provider/model agnostic: change a variable, not the code.
# Tre ambiti SEPARATI, mai incrociati: Agnos LLM (chatbot/reasoning), OCR, Extraction.
AI_RUNTIME=agno

# ─────────────────────────────────────────────────────────────────────────────
# 1) AGNOS LLM — chatbot / reasoning. Legge SOLO le AGNOS_LLM_* (priorità), poi
#    come fallback il legacy AI_AGENT_MODEL. Cambia provider/modello da qui, non nel codice.
# AGNOS_LLM_PROVIDER=azure-openai        # es: azure-openai | google | openai | anthropic | mistral
# AGNOS_LLM_MODEL=gpt-5.4-mini           # per azure = nome del deployment
# AGNOS_LLM_TEMPERATURE=0.2
# AGNOS_LLM_MAX_TOKENS=4096
# AGNOS_LLM_TIMEOUT_MS=30000
# AGNOS_LLM_STREAMING_ENABLED=true
# Solo se AGNOS_LLM_PROVIDER=azure-openai (SECRETS / endpoint):
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini   # alternativa a AGNOS_LLM_MODEL
# AZURE_OPENAI_API_KEY=
#
# Legacy fallback (usato SOLO se AGNOS_LLM_PROVIDER non è impostato):
AI_AGENT_MODEL=google:gemini-2.0-flash

# ─────────────────────────────────────────────────────────────────────────────
# 2) OCR — lettura scansioni. Legge SOLO AI_OCR_* + MISTRAL_*. Mai le AGNOS_LLM_*.
AI_OCR_PROVIDER=mistral
AI_OCR_MODEL=mistral-document-ai-2505
# MISTRAL_OCR_URL=
# MISTRAL_API_KEY=                       # SECRET

# ─────────────────────────────────────────────────────────────────────────────
# 3) EXTRACTION — estrazione dati strutturati. Legge SOLO AI_EXTRACTION_*. Mai AGNOS/OCR.
AI_EXTRACTION_PROVIDER=mistral
AI_EXTRACTION_MODEL=mistral-document-ai-2505

# Repair (percorso legacy, nessun ambito dedicato):
AI_REPAIR_MODEL=google:gemma-4-31b-it

# Optional fallbacks (either spelling works):
# AI_OCR_FALLBACK_MODEL=openai:gpt-4o
# AI_FALLBACK_EXTRACTION_MODEL=anthropic:claude-3-5-sonnet

# ─────────────────────────────────────────────────────────────────────────────
# Runtime settings — SEPARATI dalla config dei modelli (non provider/model):
AI_MAX_RETRIES=2
AI_JOB_MAX_DURATION_SECONDS=1800
AI_MAX_CONCURRENCY=2
AI_PROVIDER_TIMEOUT_SECONDS=300
# AI_OCR_TIMEOUT_SECONDS=300

# Capability requirements per role (gate incompatible models):
AI_REQUIRE_IMAGE_INPUT=true
AI_REQUIRE_FILE_INPUT=true
AI_REQUIRE_TOOL_CALLING=false
AI_REQUIRE_NATIVE_STRUCTURED_OUTPUT=false

# Auth between ClinicOS backend and the runtime (SECRET):
AI_RUNTIME_SERVICE_TOKEN=

# Provider credentials — only the providers you actually configure (SECRETS):
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# OPENAI_LIKE_API_KEY=
# OPENAI_LIKE_BASE_URL=
# MISTRAL_API_KEY=
