+.discharge-therapy-review__badge.is-verify {
+  background: var(--red-bg);
+  color: var(--red);
+}
+.discharge-therapy-review__badge.is-ok {
+  background: var(--blue-bg, #e8f0fe);
+  color: var(--blue);
+}
+.discharge-therapy-review__original {
+  margin: 0 0 12px;
+  padding: 8px 12px;
+  border-left: 3px solid var(--blue);
+  background: var(--bg);
+  border-radius: 0 8px 8px 0;
+  font-size: 13px;
+  line-height: 1.5;
+  color: var(--text-muted);
+  white-space: pre-wrap;
+}
+.discharge-therapy-review__original-label {
+  font-weight: 700;
+  color: var(--text);
+}
+.discharge-therapy-review__hint {
+  font-size: 12px;
+  color: var(--text-muted);
+  margin: 4px 0 0;
+}
+
+/* ── #281: intake final recap (StepVerifica) — readable, card-based summary ── */
+.step-verifica {
+  display: flex;
+  flex-direction: column;
+  gap: 14px;
+}
+.step-verifica__title {
+  font-size: 18px;
+  font-weight: 700;
+  color: var(--text);
+  margin: 0;
+}
+.step-verifica__section {
+  border: 1px solid var(--border);
+  border-radius: 12px;
+  background: var(--surface, #fff);
+  padding: 14px 16px;
+}
+.step-verifica__section-title {
+  font-size: 13px;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+  color: var(--text-muted);
+  margin: 0 0 10px;
+}
+.step-verifica__dl {
+  display: grid;
+  grid-template-columns: 1fr;
+  gap: 6px 16px;
+  margin: 0;
+}
+.step-verifica__row {
+  display: grid;
+  grid-template-columns: 150px 1fr;
+  gap: 12px;
+  font-size: 14px;
+}
+.step-verifica__row dt {
+  color: var(--text-muted);
+  font-weight: 600;
+}
+.step-verifica__row dd {
+  margin: 0;
+  color: var(--text);
+  overflow-wrap: anywhere;
+}
+.step-verifica__empty {
+  color: var(--text-muted);
+  font-style: normal;
+}
+.step-verifica__filled-list {
+  margin: 0;
+  padding: 0 0 0 2px;
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+  font-size: 14px;
+  color: var(--text);
+}
+.step-verifica__filled-list li {
+  padding: 6px 10px;
+  background: var(--bg);
+  border-radius: 8px;
+}
+.step-verifica__accept {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  margin-top: 12px;
+  font-size: 14px;
+  font-weight: 600;
+  color: var(--text);
+  cursor: pointer;
+}
+.step-verifica__accept input {
+  width: 16px;
+  height: 16px;
+  accent-color: var(--blue);
+}
+.step-verifica__blocks {
+  border-color: var(--red);
+  background: var(--red-bg);
+}
+.step-verifica__checklist {
+  margin: 0;
+  padding: 0;
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+  font-size: 14px;
+}
+.step-verifica__checklist li {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+.step-verifica__checklist li.is-ok {
+  color: var(--text-muted);
+}
+.step-verifica__checklist li.is-todo {
+  color: var(--red);
+  font-weight: 600;
+}
+.step-verifica__checklist svg {
+  width: 14px;
+  height: 14px;
+}
+.step-verifica__actions {
+  display: flex;
+  justify-content: flex-end;
+  padding-top: 2px;
+}
+@media (min-width: 720px) {
+  .step-verifica__dl {
+    grid-template-columns: 1fr 1fr;
+  }
+}
