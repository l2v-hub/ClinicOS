{
  "name": "clinicos",
  "version": "1.0.0",
  "private": true,
  "description": "ClinicOS full-stack monorepo with React, Vite, Express, Prisma, and PostgreSQL",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "db:generate": "npm --prefix backend run prisma:generate",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "db:seed": "npm --prefix backend run prisma:seed",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "test:e2e:full-patient:api": "tsx scripts/e2e-full-patient-api-test.ts",
    "lint": "npm run lint -w frontend && npm run lint -w backend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test -w backend && npm run test -w frontend",
    "prepare": "husky",
    "security:scan-frontend": "node scripts/security/scan-frontend-secrets.mjs frontend/src frontend/index.html",
    "quality-gate:start": "node scripts/quality-gate/create-task-contract.js",
    "quality-gate:validate": "node scripts/quality-gate/validate-task-contract.js",
    "quality-gate:check-closure": "node scripts/quality-gate/check-closure.js",
    "agent-team:doctor": "node agent-team/src/cli.mjs doctor",
    "agent-team:once": "node agent-team/src/cli.mjs once",
    "agent-team:start": "node agent-team/src/cli.mjs start",
    "agent-team:status": "node agent-team/src/cli.mjs status",
    "agent-team:stop": "node agent-team/src/cli.mjs stop"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "playwright": "1.61.1",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,html}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "clinicos",
    "clinic",
    "react",
    "vite",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "ClinicOS Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
