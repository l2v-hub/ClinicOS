{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clinic-os-agent-team development_handoff v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_type",
    "message_id",
    "correlation_id",
    "producer_role",
    "repository",
    "issue_number",
    "pull_request_number",
    "attempt",
    "created_at",
    "subject_sha",
    "state_before",
    "state_after",
    "acceptance_criteria",
    "resolved_findings",
    "commands",
    "artifact_refs",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "message_type": { "const": "development_handoff" },
    "message_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "correlation_id": { "type": "string", "pattern": "^issue-[0-9]+-attempt-[0-9]+$" },
    "producer_role": { "enum": ["claude-development", "codex-qa", "agent-team-supervisor"] },
    "repository": { "const": "l2v-hub/ClinicOS" },
    "issue_number": { "type": "integer" },
    "pull_request_number": { "type": "integer" },
    "attempt": { "type": "integer" },
    "created_at": { "type": "string" },
    "subject_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "state_before": { "type": "string" },
    "state_after": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_refs"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["passed", "failed", "not-applicable", "unresolved"] },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "resolved_findings": { "type": "array", "items": { "type": "string" } },
    "unresolved_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "status", "reason", "owner"],
        "properties": {
          "finding_id": { "type": "string" },
          "status": { "const": "unresolved" },
          "reason": { "type": "string" },
          "owner": { "enum": ["repository-owner", "codex-qa", "claude-development"] }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "argv",
          "cwd",
          "exit_code",
          "started_at",
          "finished_at",
          "stdout_ref",
          "stderr_ref"
        ],
        "properties": {
          "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "cwd": { "type": "string" },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" },
          "stdout_ref": { "type": "string" },
          "stderr_ref": { "type": "string" }
        }
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "media_type",
          "sha256",
          "git_blob_sha",
          "producer_role",
          "subject_sha"
        ],
        "properties": {
          "path": { "type": "string" },
          "media_type": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "git_blob_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "producer_role": { "enum": ["claude-development", "codex-qa"] },
          "subject_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        }
      }
    },
    "next_actions": { "type": "array", "items": { "enum": ["ready-for-qa"] } }
  }
}
