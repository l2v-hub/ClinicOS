{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clinic-os-agent-team worker.blocked v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "message_type", "message_id", "correlation_id", "producer_role", "repository", "issue_number", "attempt", "created_at", "reason", "qa_history"],
  "properties": {
    "schema_version": { "const": 1 },
    "message_type": { "const": "worker.blocked" },
    "message_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "correlation_id": { "type": "string", "pattern": "^issue-[0-9]+-attempt-[0-9]+$" },
    "producer_role": { "enum": ["claude-development", "codex-qa", "agent-team-supervisor"] },
    "repository": { "const": "l2v-hub/ClinicOS" },
    "issue_number": { "type": "integer" },
    "pull_request_number": { "type": "integer" },
    "attempt": { "type": "integer" },
    "created_at": { "type": "string" },
    "reason": { "type": "string" },
    "state_before": { "type": "string" },
    "state_after": { "type": "string" },
    "qa_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attempt", "subject_sha", "decision"],
        "properties": { "attempt": { "type": "integer" }, "subject_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }, "decision": { "enum": ["qa-passed", "qa-failed", "blocked"] } }
      }
    }
  }
}
